{
  "name": "pi-safety-modes",
  "version": "0.1.1",
  "type": "module",
  "description": "Pi package providing safety modes for tool-call guardrails",
  "license": "MIT",
  "homepage": "https://github.com/adstastic/pi-safety-modes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adstastic/pi-safety-modes.git"
  },
  "bugs": {
    "url": "https://github.com/adstastic/pi-safety-modes/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "safety",
    "guardrails"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "skills",
    "README.md",
    "LICENSE",
    "config.example.json"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.8"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
